# =============================================================================
# BETTING APPLICATION - ENVIRONMENT CONFIGURATION
# =============================================================================
# This file contains all environment variables actually used by the application
# Copy this file to .env and update the values for your environment

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
# Main MongoDB connection URL
MONGO_URL=your_mongodb_connection_url

# =============================================================================
# JWT AUTHENTICATION CONFIGURATION
# =============================================================================
# JWT secret key (use strong, random secret in production)
JWT_SECRET=your_jwt_secret

# JWT algorithm
JWT_ALGORITHM=HS256

# JWT token expiration times
ACCESS_TOKEN_EXPIRE_MINUTES=1440
ACCESS_TOKEN_EXPIRE_MINUTES_REMEMBER=43200
REFRESH_TOKEN_EXPIRE_DAYS=30

# Password reset configuration
RESET_TOKEN_SECRET=your_reset_token_secret

# =============================================================================
# EMAIL SERVICE CONFIGURATION (SMTP)
# =============================================================================
# SMTP server settings
EMAIL_HOST=your_email_host
EMAIL_PORT=587
EMAIL_HOST_USER=your_email_username
EMAIL_HOST_PASSWORD=your_email_password
EMAIL_FROM=your_email_from

# Legacy SMTP variables (for backward compatibility)
SMTP_SERVER=your_smtp_server
SMTP_PORT=587
SMTP_USERNAME=your_smtp_username
SMTP_PASSWORD=your_smtp_password
SMTP_USE_SSL=true
FROM_EMAIL=your_from_email
FROM_NAME=your_from_name

# =============================================================================
# SMS SERVICE CONFIGURATION (TWILIO)
# =============================================================================
# Twilio credentials for OTP and SMS
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=your_twilio_phone_number

# =============================================================================
# PAYMENT PROCESSING (STRIPE)
# =============================================================================
# Stripe API keys
STRIPE_SECRET_KEY=your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret

# =============================================================================
# SOCIAL LOGIN CONFIGURATION
# =============================================================================
# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Apple OAuth
APPLE_CLIENT_ID=your_apple_client_id
APPLE_TEAM_ID=your_apple_team_id
APPLE_KEY_ID=your_apple_key_id
APPLE_PRIVATE_KEY=your_apple_private_key

# =============================================================================
# APPLICATION CONFIGURATION
# =============================================================================
# Base URLs
APP_BASE_URL=your_app_base_url
ADMIN_BASE_URL=your_admin_base_url
FRONTEND_URL=your_frontend_url

# Environment settings
ENVIRONMENT=development

# Server configuration
HOST=0.0.0.0
PORT=8000

# =============================================================================
# FILE UPLOAD CONFIGURATION
# =============================================================================
# Upload directories and limits
UPLOAD_BASE_DIR=uploads
MAX_FILE_SIZE=10485760

# =============================================================================
# DEVELOPMENT SETTINGS
# =============================================================================
# Database seeding settings
AUTO_SEED_ENABLED=true

# Payment bypass for development
ALLOW_PAYMENT_BYPASS=false
